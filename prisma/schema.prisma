generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth (NextAuth)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  workouts            Workout[]
  exerciseTemplates   ExerciseTemplate[]
  bodyWeights         BodyWeight[]
  waterIntakes        WaterIntake[]
  accounts            Account[]
  sessions            Session[]
  exercisePreferences ExercisePreference[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Exercise library
// ---------------------------------------------------------------------------

// Equipment category
enum EquipmentType {
  BARBELL
  DUMBBELL
  MACHINE
  CABLE
  BODYWEIGHT
  OTHER
}

// Muscle group
enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  GLUTES
  CORE
  CALVES
  FOREARMS
  FULL_BODY
  OTHER
}

// Exercise template — global (userId null) or created by the user
model ExerciseTemplate {
  id            String        @id @default(cuid())
  name          String
  equipment     EquipmentType @default(OTHER)
  primaryMuscle MuscleGroup   @default(OTHER)
  notes         String?
  isGlobal      Boolean       @default(false) // true = built-in, false = user-created
  userId        String? // null when isGlobal = true
  user          User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  exercises   Exercise[]
  preferences ExercisePreference[]

  @@unique([name, isGlobal])
}

enum ExerciseReaction {
  LIKED
  DISLIKED
}

model ExercisePreference {
  id         String           @id @default(cuid())
  userId     String
  templateId String
  reaction   ExerciseReaction
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   ExerciseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

// ---------------------------------------------------------------------------
// Workouts
// ---------------------------------------------------------------------------

model Workout {
  id        String     @id @default(cuid())
  name      String
  date      DateTime   @default(now())
  notes     String?
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises Exercise[]
  createdAt DateTime   @default(now())
}

model Exercise {
  id                 String            @id @default(cuid())
  order              Int               @default(0)
  notes              String?
  // Machine settings (optional)
  machineSettings    String? // e.g. "seat: 4, backrest: 2"
  workoutId          String
  workout            Workout           @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  templateId         String?
  template           ExerciseTemplate? @relation(fields: [templateId], references: [id])
  sets               Set[]
}

// Set technique quality
enum SetQuality {
  GREEN  // good technique
  YELLOW // average
  RED    // poor / too heavy
}

model Set {
  id         String      @id @default(cuid())
  order      Int         @default(0)
  reps       Int
  weight     Float
  unit       String      @default("kg")
  quality    SetQuality?
  notes      String?
  exerciseId String
  exercise   Exercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Body log
// ---------------------------------------------------------------------------

model BodyWeight {
  id        String   @id @default(cuid())
  weight    Float
  unit      String   @default("kg")
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date]) // one entry per day
}

model WaterIntake {
  id        String   @id @default(cuid())
  amount    Float // in ml
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
